[gd_scene load_steps=2 format=3 uid="uid://mesh_origin_dock"]

[ext_resource type="Script" path="res://addons/mesh-origin-editor/origin_dock.gd" id="1"]

[node name="OriginDock" type="VBoxContainer"]
custom_minimum_size = Vector2(180, 0)
script = ExtResource("1")

[node name="Label" type="Label" parent="."]
text = "Mesh Origin Editor"
theme_override_font_sizes/font_size = 14

[node name="HSeparator" type="HSeparator" parent="."]

[node name="StatusLabel" type="Label" parent="."]
autowrap_mode = 3
text = "Select a MeshInstance3D"

[node name="HSeparator2" type="HSeparator" parent="."]

[node name="CenterBtn" type="Button" parent="."]
disabled = true
text = "Center to AABB"
tooltip_text = "Moves mesh origin to the center of its bounding box."

[node name="BottomBtn" type="Button" parent="."]
disabled = true
text = "Origin to Bottom-Center"
tooltip_text = "Moves mesh origin to the bottom-center of its bounding box.\nUseful for characters/objects that sit on a floor."

[node name="TopBtn" type="Button" parent="."]
disabled = true
text = "Origin to Top-Center"
tooltip_text = "Moves mesh origin to the top-center of its bounding box."

[node name="HSeparator3" type="HSeparator" parent="."]

[node name="CustomContainer" type="VBoxContainer" parent="."]

[node name="CustomLabel" type="Label" parent="CustomContainer"]
text = "Custom offset (local space):"

[node name="HBox" type="HBoxContainer" parent="CustomContainer"]

[node name="OffsetX" type="SpinBox" parent="CustomContainer/HBox"]
custom_minimum_size = Vector2(55, 0)
min_value = -9999.0
max_value = 9999.0
step = 0.001
allow_greater = true
allow_lesser = true
prefix = "X"

[node name="OffsetY" type="SpinBox" parent="CustomContainer/HBox"]
custom_minimum_size = Vector2(55, 0)
min_value = -9999.0
max_value = 9999.0
step = 0.001
allow_greater = true
allow_lesser = true
prefix = "Y"

[node name="OffsetZ" type="SpinBox" parent="CustomContainer/HBox"]
custom_minimum_size = Vector2(55, 0)
min_value = -9999.0
max_value = 9999.0
step = 0.001
allow_greater = true
allow_lesser = true
prefix = "Z"

[node name="ApplyCustomBtn" type="Button" parent="CustomContainer"]
disabled = true
text = "Apply Custom Offset"
tooltip_text = "Shifts all vertices by the given local-space offset."
